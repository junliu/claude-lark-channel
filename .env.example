# Copy to `.env` (in this dir or your LARK_CONFIG_DIR) and fill in.
# `.env` is gitignored — never commit real credentials.
#
# NOTE: LARK_CONFIG_DIR itself must be a real env var / set on the launch command —
# it cannot live in this file, since it's what tells the server where to find this file.

LARK_APP_ID=cli_xxxxxxxx
LARK_APP_SECRET=xxxxxxxx

# webhook (default) | ws
LARK_TRANSPORT=ws

# Webhook transport only:
LARK_ENCRYPT_KEY=
LARK_VERIFY_TOKEN=
LARK_WEBHOOK_PORT=3000
LARK_WEBHOOK_PATH=/webhook/event
